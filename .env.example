# Lore needs NO environment configuration for normal local use — the desktop app
# runs SQLite + an embedded vector store out of the box.
#
# The variables below are only for the OPT-IN server-parity/dev lanes:

# Server mode (deployed team server or the docker-compose dev lane):
#DATABASE_URL=postgresql://vault:vault@localhost:5433/vault
#QDRANT_URL=http://localhost:6333

# Optional hosted embeddings/rerank (defaults to fully-local models when unset):
#VOYAGE_API_KEY=

# Backend port override (default 8099):
#LORE_PORT=8099
