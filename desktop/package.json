{
  "name": "lore-desktop",
  "productName": "Lore",
  "version": "0.1.0-beta.2",
  "description": "Lore — Knowledge OS desktop app (file explorer + cited recall)",
  "main": "main.js",
  "author": "Anish Ivaturi",
  "license": "UNLICENSED",
  "scripts": {
    "build:renderer": "node scripts/build-renderer.cjs",
    "prestart": "npm run build:renderer",
    "predist": "npm run build:renderer",
    "predist:mac": "npm run build:renderer",
    "predist:linux": "npm run build:renderer",
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.6.0",
    "playwright": "^1.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.9",
    "embedded-postgres": "^18.4.0-beta.17"
  },
  "build": {
    "appId": "co.lore.desktop",
    "productName": "Lore",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "lib/**/*",
      "scraper.js",
      "hooks-installer.js",
      "mcp-installer.js",
      "cli-installer.js",
      "wizards-catalog.json",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../core/pyi-dist/lore-backend",
        "to": "lore-backend"
      }
    ],
    "asarUnpack": [
      "node_modules/embedded-postgres/**"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "mac": {
      "icon": "assets/icon-mac.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "Anish-I"
    },
    "publish": {
      "provider": "github",
      "owner": "Anish-I",
      "repo": "lore"
    },
    "artifactName": "Lore-${version}-${os}-${arch}.${ext}"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Anish-I/lore.git"
  }
}
